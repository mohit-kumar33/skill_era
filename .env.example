# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgresql://apex:apex_secret@localhost:5432/skill_era?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skill_era
DB_USER=apex
DB_PASSWORD=apex_secret
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-to-a-64-char-random-hex
JWT_REFRESH_SECRET=change-this-to-another-64-char-random-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Webhook ────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=change-this-to-gateway-provided-secret

# ── Payout Gateway ─────────────────────────────────────
PAYOUT_API_URL=https://api.paymentgateway.com/payouts
PAYOUT_API_KEY=change-this

# ── Gateway Reconciliation ─────────────────────────────
GATEWAY_API_URL=https://api.paymentgateway.com
GATEWAY_API_KEY=change-this

# ── TDS Configuration (Section 194BA) ──────────────────
TDS_THRESHOLD_INR=10000
TDS_RATE_PERCENT=30
TDS_NO_PAN_RATE_PERCENT=30
