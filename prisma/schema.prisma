// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum AccountStatus {
  active
  suspended
  frozen
  banned
  pending_deletion
  deleted
}

enum KycStatus {
  pending
  submitted
  verified
  rejected
}

enum UserRole {
  user
  admin
  finance_admin
  super_admin
}

enum TransactionType {
  deposit
  entry_fee
  prize
  withdrawal
  refund
  commission
  tds
  gst
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

enum DepositStatus {
  initiated
  confirmed
  failed
  expired
}

enum WithdrawalStatus {
  requested
  under_review
  approved
  paid
  rejected
  failed
}

enum TournamentStatus {
  draft
  open
  in_progress
  completed
  cancelled
}

enum ParticipantResult {
  pending
  won
  lost
  draw
}

enum MatchResultStatus {
  submitted
  verified
  disputed
  rejected
}

enum FraudFlagType {
  multi_ip
  deposit_withdraw_velocity
  large_withdrawal
  high_win_ratio
  duplicate_kyc
  failed_logins
  high_balance_withdrawal
  device_fingerprint
  same_ip_1v1
  manual_flag
}

// ═══════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════

model User {
  id                String        @id @default(uuid()) @db.Uuid
  mobile            String        @unique @db.VarChar(20)
  email             String?       @unique @db.VarChar(255)
  passwordHash      String        @map("password_hash") @db.Text
  dateOfBirth       DateTime?     @map("date_of_birth") @db.Date
  ageVerified       Boolean       @default(false) @map("age_verified")
  accountStatus     AccountStatus @default(active) @map("account_status")
  kycStatus         KycStatus     @default(pending) @map("kyc_status")
  kycDocType        String?       @map("kyc_doc_type") @db.VarChar(50)
  kycDocNumber      String?       @map("kyc_doc_number") @db.VarChar(100)
  kycDocUrl         String?       @map("kyc_doc_url") @db.Text

  /// PAN stored as AES-256-GCM encrypted value. Never stored plaintext.
  panNumber         String?       @map("pan_number") @db.VarChar(10)   // DEPRECATED: migrate to encrypted_pan
  encryptedPan      String?       @map("encrypted_pan") @db.Text
  panIv             String?       @map("pan_iv") @db.Text
  panAuthTag        String?       @map("pan_auth_tag") @db.Text

  fraudScore        Int           @default(0) @map("fraud_score")
  role              UserRole      @default(user)
  state             String?       @db.VarChar(50)

  /// 2FA: stored encrypted (AES-256-GCM). twoFactorSecret kept for migration window — drop after running migrate_encrypt_fields.ts
  twoFactorSecret   String?       @map("two_factor_secret") @db.VarChar(100) // DEPRECATED
  encrypted2faSecret String?      @map("encrypted_2fa_secret") @db.Text
  totpIv            String?       @map("totp_iv") @db.Text
  totpAuthTag       String?       @map("totp_auth_tag") @db.Text
  twoFaEnabled      Boolean       @default(false) @map("two_fa_enabled")

  /// TOTP lockout tracking: fail counter resets on successful verification
  totpFailCount     Int           @default(0) @map("totp_fail_count")
  totpLockoutUntil  DateTime?     @map("totp_lockout_until") @db.Timestamptz()

  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz()


  wallet              Wallet?
  walletTransactions   WalletTransaction[]
  deposits             Deposit[]
  withdrawals          Withdrawal[]
  participants         Participant[]
  matchResults         MatchResult[]
  fraudFlags           FraudFlag[]
  adminLogs            AdminLog[]         @relation("AdminActions")
  targetedAdminLogs    AdminLog[]         @relation("AdminTargets")
  tournamentsCreated   Tournament[]
  refreshTokens        RefreshToken[]

  /// Responsible Gaming: self-exclusion end timestamp
  selfExclusionUntil  DateTime?   @map("self_exclusion_until") @db.Timestamptz()

  /// DPDP Act: account deletion tracking
  deletionRequestedAt  DateTime?  @map("deletion_requested_at") @db.Timestamptz()
  deletionScheduledFor DateTime?  @map("deletion_scheduled_for") @db.Timestamptz()
  deletionExecutedAt   DateTime?  @map("deletion_executed_at") @db.Timestamptz()

  @@index([accountStatus])
  @@index([kycStatus])
  @@index([createdAt])
  @@index([kycDocType, kycDocNumber])  // Cross-user KYC duplicate detection
  @@map("users")
}

model RefreshToken {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @map("token_hash") @db.Text
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz
  isRevoked     Boolean   @default(false) @map("is_revoked")
  replacedById  String?   @unique @map("replaced_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken? @relation("TokenRotation", fields: [replacedById], references: [id])
  replaces   RefreshToken? @relation("TokenRotation")

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Wallet {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  depositBalance  Decimal   @default(0) @map("deposit_balance") @db.Decimal(18, 2)
  winningBalance  Decimal   @default(0) @map("winning_balance") @db.Decimal(18, 2)
  bonusBalance    Decimal   @default(0) @map("bonus_balance") @db.Decimal(18, 2)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("wallets")
}

/// IMMUTABLE — Protected by DB triggers against UPDATE/DELETE
model WalletTransaction {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  referenceId     String?           @map("reference_id") @db.Uuid
  transactionType TransactionType   @map("transaction_type")
  debitAmount     Decimal           @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount    Decimal           @default(0) @map("credit_amount") @db.Decimal(18, 2)
  balanceBefore   Decimal           @map("balance_before") @db.Decimal(18, 2)
  balanceAfter    Decimal           @map("balance_after") @db.Decimal(18, 2)
  status          TransactionStatus
  idempotencyKey  String            @unique @map("idempotency_key") @db.VarChar(255)
  description     String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([referenceId])
  @@index([status])
  @@index([createdAt])
  @@index([transactionType])
  @@map("wallet_transactions")
}

model Deposit {
  id                    String        @id @default(uuid()) @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  amount                Decimal       @db.Decimal(18, 2)
  gatewayTransactionId  String?       @unique @map("gateway_transaction_id") @db.VarChar(255)
  status                DepositStatus @default(initiated)
  idempotencyKey        String        @unique @map("idempotency_key") @db.VarChar(255)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("deposits")
}

model Withdrawal {
  id                  String            @id @default(uuid()) @db.Uuid
  userId              String            @map("user_id") @db.Uuid
  amount              Decimal           @db.Decimal(18, 2)
  status              WithdrawalStatus  @default(requested)
  fraudScoreSnapshot  Int               @default(0) @map("fraud_score_snapshot")
  tdsAmount           Decimal           @default(0) @map("tds_amount") @db.Decimal(18, 2)
  netAmount           Decimal?          @map("net_amount") @db.Decimal(18, 2)
  adminApprovedBy     String?           @map("admin_approved_by") @db.Uuid
  dualApprovedBy      String?           @map("dual_approved_by") @db.Uuid
  adminNotes          String?           @map("admin_notes") @db.Text
  gatewayPayoutId     String?           @map("gateway_payout_id") @db.VarChar(255)
  idempotencyKey      String            @unique @map("idempotency_key") @db.VarChar(255)
  /// UUID v4 generated at payout execution — UNIQUE constraint prevents double-payout
  payoutReferenceId   String?           @unique @map("payout_reference_id") @db.Uuid
  /// Stores gateway error message when status = 'failed'
  payoutError         String?           @map("payout_error") @db.Text
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz()
  processedAt         DateTime?         @map("processed_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([payoutReferenceId])
  @@index([createdAt])
  @@map("withdrawals")
}

model Tournament {
  id                String           @id @default(uuid()) @db.Uuid
  gameType          String           @default("chess") @map("game_type") @db.VarChar(50)
  title             String           @db.VarChar(255)
  entryFee          Decimal          @map("entry_fee") @db.Decimal(18, 2)
  prizePool         Decimal          @default(0) @map("prize_pool") @db.Decimal(18, 2)
  commissionPercent Decimal          @map("commission_percent") @db.Decimal(5, 2)
  maxParticipants   Int              @map("max_participants")
  status            TournamentStatus @default(draft)
  scheduledAt       DateTime         @map("scheduled_at") @db.Timestamptz()
  createdBy         String           @map("created_by") @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  creator       User          @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  participants  Participant[]
  matchResults  MatchResult[]

  @@index([status])
  @@index([scheduledAt])
  @@map("tournaments")
}

model Participant {
  id              String            @id @default(uuid()) @db.Uuid
  tournamentId    String            @map("tournament_id") @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  resultStatus    ParticipantResult @default(pending) @map("result_status")
  rank            Int?
  prizeWon        Decimal?          @map("prize_won") @db.Decimal(18, 2)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Restrict)
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([tournamentId, userId])
  @@index([userId])
  @@map("participants")
}

model MatchResult {
  id              String            @id @default(uuid()) @db.Uuid
  tournamentId    String            @map("tournament_id") @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  screenshotUrl   String?           @map("screenshot_url") @db.Text
  externalMatchId String?           @map("external_match_id") @db.VarChar(255)
  verifiedBy      String?           @map("verified_by") @db.Uuid
  status          MatchResultStatus @default(submitted)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Restrict)
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([tournamentId])
  @@index([userId])
  @@map("match_results")
}

model FraudFlag {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  flagType    FraudFlagType @map("flag_type")
  riskPoints  Int           @map("risk_points")
  description String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  resolvedAt  DateTime?     @map("resolved_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([flagType])
  @@index([createdAt])
  @@map("fraud_flags")
}

/// IMMUTABLE — Protected by DB trigger against UPDATE/DELETE
model AdminLog {
  id            String   @id @default(uuid()) @db.Uuid
  adminId       String   @map("admin_id") @db.Uuid
  actionType    String   @map("action_type") @db.VarChar(100)
  targetUserId  String?  @map("target_user_id") @db.Uuid
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  metadata      Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  admin      User  @relation("AdminActions", fields: [adminId], references: [id], onDelete: Restrict)
  targetUser User? @relation("AdminTargets", fields: [targetUserId], references: [id], onDelete: Restrict)

  @@index([adminId])
  @@index([targetUserId])
  @@index([actionType])
  @@index([createdAt])
  @@map("admin_logs")
}

model TreasurySnapshot {
  id                  String   @id @default(uuid()) @db.Uuid
  totalUserBalance    Decimal  @map("total_user_balance") @db.Decimal(18, 2)
  pendingWithdrawals  Decimal  @map("pending_withdrawals") @db.Decimal(18, 2)
  settlementPending   Decimal  @default(0) @map("settlement_pending") @db.Decimal(18, 2)
  liquidityRatio      Decimal  @map("liquidity_ratio") @db.Decimal(10, 4)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([createdAt])
  @@map("treasury_snapshots")
}

model ReconciliationLog {
  id                  String   @id @default(uuid()) @db.Uuid
  type                String   @db.VarChar(50)
  referenceId         String?  @map("reference_id") @db.Uuid
  gatewayReference    String   @map("gateway_reference") @db.VarChar(255)
  issueType           String   @map("issue_type") @db.VarChar(100)
  localAmount         Decimal? @map("local_amount") @db.Decimal(18, 2)
  gatewayAmount       Decimal? @map("gateway_amount") @db.Decimal(18, 2)
  reconciliationDate  DateTime @default(now()) @map("reconciliation_date") @db.Date
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([referenceId, issueType, reconciliationDate])
  @@index([referenceId])
  @@index([issueType])
  @@index([reconciliationDate])
  @@map("reconciliation_logs")
}
